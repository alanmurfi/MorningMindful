<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/narrativeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:paddingHorizontal="48dp">

        <TextView
            android:id="@+id/narrativeLine1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:fontFamily="sans-serif-light"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:lineSpacingExtra="4dp" />

        <TextView
            android:id="@+id/narrativeLine2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:fontFamily="sans-serif-light"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:lineSpacingExtra="4dp" />

        <TextView
            android:id="@+id/narrativeLine3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:fontFamily="sans-serif-light"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:lineSpacingExtra="4dp" />

        <TextView
            android:id="@+id/narrativeLine4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:fontFamily="sans-serif-light"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:lineSpacingExtra="4dp" />

        <TextView
            android:id="@+id/narrativeLine5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:fontFamily="sans-serif-light"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

    <!-- Tap to continue hint -->
    <TextView
        android:id="@+id/tapToContinue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="48dp"
        android:layout_marginEnd="32dp"
        android:alpha="0"
        android:text="@string/tap_to_continue"
        android:textColor="#99FFFFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif-light" />

    <!-- Continue button (only for SOLUTION page) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/narrativeContinueButton"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom|center"
        android:layout_marginBottom="48dp"
        android:layout_marginHorizontal="48dp"
        android:alpha="0"
        android:text="@string/next"
        android:textColor="@color/primary"
        android:textSize="16sp"
        android:visibility="gone"
        app:backgroundTint="@android:color/white"
        app:cornerRadius="28dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</FrameLayout>
