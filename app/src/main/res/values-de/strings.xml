    <!-- Accessibility Service -->
    <string name="accessibility_service_description">Morning Mindful nutzt die Bedienungshilfe, um zu erkennen, wenn du während deiner Morgen-Achtsamkeitszeit gesperrte Apps öffnest. So kann die App dich stattdessen zu deinem Tagebuch weiterleiten. Es werden keine persönlichen Daten gesammelt oder geteilt.</string>

    <!-- Notifications -->
    <string name="notification_title">Morning Mindful aktiv</string>
    <string name="notification_text">Vervollständige dein Tagebuch, um Apps zu entsperren</string>

    <!-- Onboarding -->
    <string name="onboarding_welcome_title">Willkommen bei Morning Mindful</string>
    <string name="onboarding_welcome_desc">Hol dir deine Morgen zurück.\n\nDu verdienst es, den Tag nach deinen Regeln zu beginnen — nicht mit dem Feed anderer Leute.</string>

    <string name="onboarding_problem_title">Erobere deine Morgen zurück</string>
    <string name="onboarding_problem_desc">Der Durchschnittsmensch greift innerhalb von 3 Minuten nach dem Aufwachen zum Handy — und verbringt über 30 Minuten in sozialen Medien, bevor er aufsteht.\n\nDas sind über 180 Stunden pro Jahr, die durch Doom-Scrolling verloren gehen, bevor der Tag überhaupt beginnt.</string>

    <string name="onboarding_how_it_works_title">So funktioniert\'s</string>
    <string name="onboarding_how_it_works_desc">Drei einfache Schritte, jeden Morgen:</string>
    <string name="onboarding_step1_title">Öffne eine Social-Media-App</string>
    <string name="onboarding_step1_desc">Instagram, TikTok, X — wir erkennen es</string>
    <string name="onboarding_step2_title">Werde zum Tagebuch weitergeleitet</string>
    <string name="onboarding_step2_desc">Schreibe ein paar Worte über deinen Morgen</string>
    <string name="onboarding_step3_title">Apps entsperrt</string>
    <string name="onboarding_step3_desc">Fertig! Deine Apps sind für den Rest des Tages frei</string>

    <string name="onboarding_duration_title">Sperrdauer</string>
    <string name="onboarding_duration_desc">Wie lange sollen Apps nach dem Entsperren deines Handys gesperrt sein?</string>

    <string name="onboarding_wordcount_title">Wortanzahl</string>
    <string name="onboarding_wordcount_desc">Wie viele Wörter möchtest du schreiben, um deine Apps zu entsperren?</string>

    <string name="onboarding_window_title">Morgenfenster</string>
    <string name="onboarding_window_desc">Wann soll die Sperre aktiv sein?\n\nAußerhalb dieser Zeiten werden deine Apps nicht gesperrt.</string>

    <string name="onboarding_perm_accessibility_title">Bedienungshilfe-Berechtigung</string>
    <string name="onboarding_perm_accessibility_desc">Diese Berechtigung wird für den Vollständigen Sperrmodus benötigt, um Apps sofort zu erkennen und zu sperren.\n\nAndroid zeigt eine Warnung, aber wir nutzen sie nur, um zu sehen, welche App du geöffnet hast - nichts anderes.</string>

    <string name="onboarding_perm_overlay_title">Anzeige-Berechtigung</string>
    <string name="onboarding_perm_overlay_desc">Wir benötigen diese Berechtigung, um den Tagebuchbildschirm anzuzeigen, wenn du eine gesperrte App öffnest.</string>

    <string name="onboarding_perm_usage_stats_title">Nutzungszugriff-Berechtigung</string>
    <string name="onboarding_perm_usage_stats_desc">Wir benötigen diese Berechtigung, um zu sehen, welche App du verwendest, damit wir sanfte Erinnerungen anzeigen können.</string>

    <string name="onboarding_perm_notifications_title">Benachrichtigungen erlauben</string>
    <string name="onboarding_perm_notifications_desc">Wir benötigen diese Berechtigung, um dir Erinnerungen zu zeigen und dich zu informieren, wenn deine Morgenroutine aktiv ist.</string>

    <string name="onboarding_backup_title">Schütze deine Tagebücher</string>
    <string name="onboarding_backup_desc">Deine Tagebucheinträge sind wertvoll. Wähle einen Ordner für das Auto-Backup.\n\nWenn du bereits ein Backup hast, bieten wir dir an, es wiederherzustellen. Andernfalls richten wir ein neues ein.</string>
    <string name="enable_auto_backup">Auto-Backup aktivieren</string>
    <string name="choose_backup_folder">Ordner wählen</string>
    <string name="backup_folder_selected">Backup-Ordner ausgewählt</string>
    <string name="skip_backup_setup">Vorerst überspringen</string>
    <string name="auto_backup_password_title">Backup-Passwort festlegen</string>
    <string name="auto_backup_password_message">Wähle ein Passwort, um deine Backups zu verschlüsseln. Du benötigst dieses Passwort, wenn du aus einem Backup wiederherstellst.</string>

    <string name="onboarding_ready_title">Alles bereit!</string>
    <string name="onboarding_ready_desc">Die Sperre ist von 5 bis 10 Uhr mit intelligenten Standardwerten aktiv.\n\nDu kannst alles jederzeit in den Einstellungen anpassen — Sperrdauer, Wortanzahl, Morgenfenster und mehr.</string>

